# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production only: canonical site URL (no trailing slash). Set on Vercel so Google OAuth
# returns to https://your-app.vercel.app/auth/callback instead of localhost.
# Leave unset for local dev (uses http://localhost:3000 automatically).
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
